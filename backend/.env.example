# Database connection string (dj-database-url format).
# Default if unset: sqlite file next to manage.py (good for local dev/tests).
# Docker/prod example:
DATABASE_URL=postgres://notes:notes@db:5432/notes

# Django secret key — REQUIRED in production (a dev fallback exists for local runs).
DJANGO_SECRET_KEY=change-me-in-production

# "true" for local dev, "false" in production/docker.
DJANGO_DEBUG=false

# Comma-separated list of allowed CORS origins (the frontend).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Comma-separated allowed hosts (default "*" for the challenge).
DJANGO_ALLOWED_HOSTS=*

# --- AI transcription (Whisper) — OPTIONAL -----------------------------------
# Leave OPENAI_API_KEY empty to disable AI transcription; the app then uses the
# free in-browser Web Speech dictation that's always available. Any
# OpenAI-compatible endpoint works (OpenAI by default, or Groq — see below).
OPENAI_API_KEY=
# Default OpenAI; for Groq use https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI: whisper-1 ; Groq: whisper-large-v3
WHISPER_MODEL=whisper-1
