# Internal reverse proxy for a server where TLS / ports 80-443 are owned by a
# control panel (e.g. HestiaCP). This listens on a plain local port; the panel
# terminates HTTPS and proxies the domain to it.
{
	auto_https off
	admin off
}

:3300 {
	encode gzip
	@backend path /api/* /admin/* /static/*
	handle @backend {
		reverse_proxy backend:8000
	}
	handle {
		reverse_proxy frontend:3000
	}
}
